<script type="module" src="@Assets["Components/Layout/ReconnectModal.razor.js"]"></script>

<dialog id="components-reconnect-modal" class="w-80 mx-auto mt-[20vh] p-0 border border-border rounded-lg bg-card text-card-foreground shadow-lg" data-nosnippet>
    <div class="flex flex-col items-center gap-4 p-6">
        <div class="components-rejoining-animation" aria-hidden="true">
            <div></div>
            <div></div>
        </div>
        <p class="components-reconnect-first-attempt-visible text-sm text-center text-muted-foreground">
            Rejoining the server...
        </p>
        <p class="components-reconnect-repeated-attempt-visible text-sm text-center text-muted-foreground">
            Rejoin failed... trying again in <span id="components-seconds-to-next-attempt" class="font-semibold text-foreground"></span> seconds.
        </p>
        <p class="components-reconnect-failed-visible text-sm text-center text-destructive">
            Failed to rejoin.<br />Please retry or reload the page.
        </p>
        <button id="components-reconnect-button" class="components-reconnect-failed-visible inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-4 bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
            Retry
        </button>
        <p class="components-pause-visible text-sm text-center text-muted-foreground">
            The session has been paused by the server.
        </p>
        <p class="components-resume-failed-visible text-sm text-center text-destructive">
            Failed to resume the session.<br />Please retry or reload the page.
        </p>
        <button id="components-resume-button" class="components-pause-visible components-resume-failed-visible inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-4 bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
            Resume
        </button>
    </div>
</dialog>
