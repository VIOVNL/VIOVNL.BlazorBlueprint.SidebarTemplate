    private readonly List<HeatmapPoint> _heatmapData = GenerateHeatmapData();
    private static List<HeatmapPoint> GenerateHeatmapData()
    {
        var days = new[] { "Mon", "Tue", "Wed", "Thu", "Fri" };
        var hours = new[] { "9am", "10am", "11am", "12pm", "1pm", "2pm", "3pm", "4pm", "5pm" };
        var rng = new Random(42);
        var data = new List<HeatmapPoint>();
        for (int d = 0; d < days.Length; d++)
            for (int h = 0; h < hours.Length; h++)
                data.Add(new(days[d], hours[h], d, h, rng.Next(10, 100)));
        return data;
    }

    // Dialog
    private async Task ShowConfirmDialog()
    {
        await DialogService.ConfirmAsync(
            "Are you sure?",
            "This action cannot be undone. This will permanently delete your data.",
            new ConfirmDialogOptions { Destructive = true, ConfirmText = "Delete" });
    }

    // Toast
    private void ShowToast()
    {
        ToastService.Show("Event created", "Your event has been scheduled successfully.", ToastVariant.Default);
    }
}
