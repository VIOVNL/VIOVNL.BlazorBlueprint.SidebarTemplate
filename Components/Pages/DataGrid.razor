    // ───── Helpers ─────
    private static BadgeVariant GetStatusVariant(string status) => status switch
    {
        "Fulfilled" => BadgeVariant.Default,
        "Processing" => BadgeVariant.Secondary,
        "Pending" => BadgeVariant.Outline,
        "Cancelled" => BadgeVariant.Destructive,
        _ => BadgeVariant.Outline
    };

    private static BadgeVariant GetLogLevelVariant(string level) => level switch
    {
        "Error" => BadgeVariant.Destructive,
        "Warning" => BadgeVariant.Secondary,
        "Info" => BadgeVariant.Outline,
        "Debug" => BadgeVariant.Outline,
        _ => BadgeVariant.Outline
    };

    private static string FormatSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
    };

