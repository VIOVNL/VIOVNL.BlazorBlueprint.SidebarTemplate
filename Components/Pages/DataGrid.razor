    private ValueTask<BlazorBlueprint.Primitives.DataGrid.DataGridResult<LogEntry>> LoadLogEntries(
        BlazorBlueprint.Primitives.DataGrid.DataGridRequest request)
    {
        var filtered = _logEntries.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(request.SearchText))
        {
            var search = request.SearchText.ToLowerInvariant();
            filtered = filtered.Where(l =>
                l.Message.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                l.Source.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                l.Level.Contains(search, StringComparison.OrdinalIgnoreCase));
        }

        var list = filtered.ToList();
        var count = request.Count ?? 50;
        var items = list.Skip(request.StartIndex).Take(count).ToList();

        return ValueTask.FromResult(new BlazorBlueprint.Primitives.DataGrid.DataGridResult<LogEntry>
        {
            Items = items,
            TotalItemCount = list.Count
        });
    }

