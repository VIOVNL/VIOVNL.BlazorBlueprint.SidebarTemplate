    // ───── Data Generators ─────
    private static List<LogEntry> GenerateLogEntries(int count)
    {
        var levels = new[] { "Info", "Info", "Info", "Warning", "Warning", "Error", "Debug", "Debug" };
        var sources = new[] { "API", "Auth", "Database", "Scheduler", "Cache", "Queue", "Storage" };
        var messages = new[]
        {
            "Request processed successfully",
            "Connection pool exhausted, waiting for available connection",
            "Failed to authenticate user, invalid token",
            "Database query took longer than threshold (2000ms)",
            "Cache miss for key: user_session_*",
            "Scheduled job completed: cleanup_expired_sessions",
            "Rate limit exceeded for IP range",
            "File upload completed, size: {0} bytes",
            "WebSocket connection established from client",
            "Retry attempt {0}/3 for external service call",
            "Memory usage above 80% threshold",
            "Configuration reloaded successfully",
            "Background worker started processing batch",
            "SSL certificate renewal check passed",
            "Health check endpoint responded OK",
        };

        var baseTime = new DateTime(2025, 3, 15, 8, 0, 0);
        return Enumerable.Range(1, count).Select(i => new LogEntry(
            i,
            baseTime.AddSeconds(i * 3.7),
            levels[Random.Shared.Next(levels.Length)],
            sources[Random.Shared.Next(sources.Length)],
            string.Format(messages[Random.Shared.Next(messages.Length)], Random.Shared.Next(100, 99999))
        )).ToList();
    }

