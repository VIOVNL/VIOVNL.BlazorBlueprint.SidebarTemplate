@page "/datagrid"

<PageTitle>Data Grid</PageTitle>

<PageWrapper Title="Data Grid" Description="Enterprise-grade data grid with sorting, filtering, grouping, and more.">
    <ActionButtons>
        <BbButton Variant="ButtonVariant.Outline" OnClick="ResetState">
            <LucideIcon Name="rotate-ccw" class="h-4 w-4 mr-2" />
            Reset
        </BbButton>
        <BbButton OnClick="AddOrder">
            <LucideIcon Name="plus" class="h-4 w-4 mr-2" />
            Add Order
        </BbButton>
    </ActionButtons>
    <ChildContent>

        @* ───── Stat Cards ───── *@
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
            <BbCard>
                <BbCardContent Class="pt-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm text-muted-foreground">Total Orders</p>
                            <p class="text-2xl font-bold tabular-nums mt-1">@_orders.Count</p>
                        </div>
                        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
                            <LucideIcon Name="shopping-cart" class="h-5 w-5 text-primary" />
                        </div>
                    </div>
                </BbCardContent>
            </BbCard>
            <BbCard>
                <BbCardContent Class="pt-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm text-muted-foreground">Revenue</p>
                            <p class="text-2xl font-bold tabular-nums mt-1">@_orders.Sum(o => o.Total).ToString("C0")</p>
                        </div>
                        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-green-500/10">
                            <LucideIcon Name="dollar-sign" class="h-5 w-5 text-green-500" />
                        </div>
                    </div>
                </BbCardContent>
            </BbCard>
            <BbCard>
                <BbCardContent Class="pt-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm text-muted-foreground">Fulfilled</p>
                            <p class="text-2xl font-bold tabular-nums mt-1">@_orders.Count(o => o.Status == "Fulfilled")</p>
                        </div>
                        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-500/10">
                            <LucideIcon Name="package-check" class="h-5 w-5 text-blue-500" />
                        </div>
                    </div>
                </BbCardContent>
            </BbCard>
            <BbCard>
                <BbCardContent Class="pt-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm text-muted-foreground">Pending</p>
                            <p class="text-2xl font-bold tabular-nums mt-1">@_orders.Count(o => o.Status == "Pending")</p>
                        </div>
                        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/10">
                            <LucideIcon Name="clock" class="h-5 w-5 text-amber-500" />
                        </div>
                    </div>
                </BbCardContent>
            </BbCard>
        </div>

        @* ───── 1. Full-Featured Orders Grid ───── *@
        <BbCard>
            <BbCardHeader>
                <BbCardTitle>Orders</BbCardTitle>
                <BbCardDescription>Full-featured grid: selection, expand, search, filter, resize, column visibility, and context menus.</BbCardDescription>
            </BbCardHeader>
            <BbCardContent Class="px-4 py-0">
                <BbDataGrid TData="OrderRow" Items="_orders"
                            SelectionMode="DataTableSelectionMode.Multiple"
                            @bind-SelectedItems="_selectedOrders"
                            Resizable="true"
                            Reorderable="true"
                            ShowSearch="true"
                            SearchPlaceholder="Search orders..."
                            InitialPageSize="10"
                            ShowPagination="true"
                            ItemKey="@(o => o.Id)"
                            OnRowExpand="@(o => { })"
                            RowClass="@(o => o.Status == "Cancelled" ? "opacity-50" : null)">
                    <Toolbar>
                        <BbDataGridColumnVisibility TData="OrderRow" />
                    </Toolbar>
                    <Columns>
                        <BbDataGridSelectColumn Pinned="BlazorBlueprint.Primitives.DataGrid.ColumnPinning.Left" />
                        <BbDataGridExpandColumn />
                        <BbDataGridPropertyColumn Property="@(o => o.Id)" Title="#" Width="80px"
                                                   Sortable="true" CellClass="tabular-nums font-mono text-xs" />
                        <BbDataGridPropertyColumn Property="@(o => o.Customer)" Sortable="true" Filterable="true" />
                        <BbDataGridPropertyColumn Property="@(o => o.Email)" Sortable="true" Filterable="true"
                                                   CellClass="text-muted-foreground text-sm" />
                        <BbDataGridTemplateColumn Title="Status" Sortable="true">
                            <ChildContent Context="order">
                                <BbBadge Variant="@GetStatusVariant(order.Status)">@order.Status</BbBadge>
                            </ChildContent>
                        </BbDataGridTemplateColumn>
                        <BbDataGridPropertyColumn Property="@(o => o.Category)" Sortable="true" Filterable="true">
                            <CellTemplate Context="order">
                                <BbBadge Variant="BadgeVariant.Outline">@order.Category</BbBadge>
                            </CellTemplate>
                        </BbDataGridPropertyColumn>
                        <BbDataGridPropertyColumn Property="@(o => o.Items)" Title="Qty" Sortable="true"
                                                   CellClass="tabular-nums" Width="80px" />
                        <BbDataGridPropertyColumn Property="@(o => o.Total)" Format="C2" Sortable="true"
                                                   CellClass="tabular-nums font-medium" />
                        <BbDataGridPropertyColumn Property="@(o => o.Date)" Format="MMM d, yyyy" Sortable="true"
                                                   CellClass="tabular-nums text-sm text-muted-foreground" />
                        <BbDataGridTemplateColumn Title="" Width="60px" Pinned="BlazorBlueprint.Primitives.DataGrid.ColumnPinning.Right">
                            <ChildContent Context="order">
                                <BbDropdownMenu>
                                    <BbDropdownMenuTrigger>
                                        <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" Class="h-8 w-8">
                                            <LucideIcon Name="ellipsis" class="h-4 w-4" />
                                        </BbButton>
                                    </BbDropdownMenuTrigger>
                                    <BbDropdownMenuContent Align="PopoverAlign.End">
                                        <BbDropdownMenuLabel>Actions</BbDropdownMenuLabel>
                                        <BbDropdownMenuSeparator />
                                        <BbDropdownMenuItem>
                                            <LucideIcon Name="eye" class="h-4 w-4 mr-2" />
                                            View Details
                                        </BbDropdownMenuItem>
                                        <BbDropdownMenuItem>
                                            <LucideIcon Name="pencil" class="h-4 w-4 mr-2" />
                                            Edit
                                        </BbDropdownMenuItem>
                                        <BbDropdownMenuItem>
                                            <LucideIcon Name="copy" class="h-4 w-4 mr-2" />
                                            Duplicate
                                        </BbDropdownMenuItem>
                                        <BbDropdownMenuSeparator />
                                        <BbDropdownMenuItem Class="text-destructive">
                                            <LucideIcon Name="trash-2" class="h-4 w-4 mr-2" />
                                            Delete
                                        </BbDropdownMenuItem>
                                    </BbDropdownMenuContent>
                                </BbDropdownMenu>
                            </ChildContent>
                        </BbDataGridTemplateColumn>
                    </Columns>
                    <DetailTemplate Context="order">
                        <div class="p-4 space-y-3">
                            <div class="flex items-center gap-2">
                                <h4 class="font-semibold text-sm">Order #@order.Id</h4>
                                <BbBadge Variant="@GetStatusVariant(order.Status)" Class="text-xs">@order.Status</BbBadge>
                            </div>
                            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
                                <div>
                                    <p class="text-muted-foreground">Customer</p>
                                    <p class="font-medium">@order.Customer</p>
                                </div>
                                <div>
                                    <p class="text-muted-foreground">Email</p>
                                    <p class="font-medium">@order.Email</p>
                                </div>
                                <div>
                                    <p class="text-muted-foreground">Category</p>
                                    <p class="font-medium">@order.Category</p>
                                </div>
                                <div>
                                    <p class="text-muted-foreground">Notes</p>
                                    <p class="font-medium">@order.Notes</p>
                                </div>
                            </div>
                        </div>
                    </DetailTemplate>
                    <RowContextMenu Context="menu">
                        <BbContextMenu>
                            <BbContextMenuContent>
                                <BbContextMenuItem OnClick="@(() => menu.CopyToClipboardAsync(menu.FormatRow(menu.Item, "\t")))">
                                    <LucideIcon Name="clipboard-copy" class="h-4 w-4 mr-2" />
                                    Copy Row
                                </BbContextMenuItem>
                                @if (menu.SelectedItems.Count > 1)
                                {
                                    <BbContextMenuItem OnClick="@(() => menu.CopyToClipboardAsync(menu.FormatRows(menu.SelectedItems, "\t")))">
                                        <LucideIcon Name="clipboard-list" class="h-4 w-4 mr-2" />
                                        Copy Selected (@menu.SelectedItems.Count rows)
                                    </BbContextMenuItem>
                                }
                                <BbContextMenuSeparator />
                                <BbContextMenuItem>
                                    <LucideIcon Name="eye" class="h-4 w-4 mr-2" />
                                    View Details
                                </BbContextMenuItem>
                                <BbContextMenuItem>
                                    <LucideIcon Name="pencil" class="h-4 w-4 mr-2" />
                                    Edit Order
                                </BbContextMenuItem>
                                <BbContextMenuSeparator />
                                <BbContextMenuItem Class="text-destructive">
                                    <LucideIcon Name="trash-2" class="h-4 w-4 mr-2" />
                                    Delete
                                </BbContextMenuItem>
                            </BbContextMenuContent>
                        </BbContextMenu>
                    </RowContextMenu>
                </BbDataGrid>
            </BbCardContent>
        </BbCard>

        @* ───── 2. Grouped Grid with Aggregates ───── *@
        <BbCard>
            <BbCardHeader>
                <BbCardTitle>Grouped by Category</BbCardTitle>
                <BbCardDescription>Row grouping with sum and average aggregates per group.</BbCardDescription>
            </BbCardHeader>
            <BbCardContent Class="px-4 py-0">
                <BbDataGrid TData="OrderRow" Items="_orders"
                            GroupBy="@(o => (object)o.Category)"
                            InitialPageSize="20"
                            ShowPagination="false">
                    <Columns>
                        <BbDataGridGroupColumn TData="OrderRow" TProperty="string"
                                                Property="@(o => o.Category)"
                                                Title="Category"
                                                GroupSortDirection="SortDirection.Ascending" />
                        <BbDataGridPropertyColumn Property="@(o => o.Customer)" Sortable="true" />
                        <BbDataGridTemplateColumn Title="Status">
                            <ChildContent Context="order">
                                <BbBadge Variant="@GetStatusVariant(order.Status)">@order.Status</BbBadge>
                            </ChildContent>
                        </BbDataGridTemplateColumn>
                        <BbDataGridPropertyColumn Property="@(o => o.Items)" Title="Qty" Sortable="true"
                                                   CellClass="tabular-nums"
                                                   Aggregate="BlazorBlueprint.Primitives.DataGrid.AggregateFunction.Sum" AggregateFormat="N0" />
                        <BbDataGridPropertyColumn Property="@(o => o.Total)" Format="C2" Sortable="true"
                                                   CellClass="tabular-nums font-medium"
                                                   Aggregate="BlazorBlueprint.Primitives.DataGrid.AggregateFunction.Sum" AggregateFormat="C2" />
                    </Columns>
                </BbDataGrid>
            </BbCardContent>
        </BbCard>

        @* ───── 3. Per-Column Filtering ───── *@
        <BbCard>
            <BbCardHeader>
                <BbCardTitle>Per-Column Filters</BbCardTitle>
                <BbCardDescription>Click the filter icon on column headers to apply per-column filters with operators.</BbCardDescription>
            </BbCardHeader>
            <BbCardContent Class="px-4 py-0">
                <BbDataGrid TData="OrderRow" Items="_orders"
                            ShowFilterBar="true"
                            InitialPageSize="5"
                            ShowPagination="true">
                    <Columns>
                        <BbDataGridPropertyColumn Property="@(o => o.Id)" Title="#" Width="80px"
                                                   Sortable="true" Filterable="true"
                                                   CellClass="tabular-nums font-mono text-xs" />
                        <BbDataGridPropertyColumn Property="@(o => o.Customer)" Sortable="true" Filterable="true" />
                        <BbDataGridPropertyColumn Property="@(o => o.Category)" Sortable="true" Filterable="true" />
                        <BbDataGridPropertyColumn Property="@(o => o.Total)" Format="C2" Sortable="true" Filterable="true"
                                                   CellClass="tabular-nums font-medium" />
                        <BbDataGridPropertyColumn Property="@(o => o.Date)" Format="MMM d, yyyy" Sortable="true" Filterable="true"
                                                   CellClass="tabular-nums text-sm text-muted-foreground" />
                    </Columns>
                </BbDataGrid>
            </BbCardContent>
        </BbCard>

        @* ───── 4. Hierarchical Tree Data ───── *@
        <BbCard>
            <BbCardHeader>
                <BbCardTitle>File Explorer</BbCardTitle>
                <BbCardDescription>Hierarchical tree data with nested children, expand/collapse, and cascade selection.</BbCardDescription>
            </BbCardHeader>
            <BbCardContent Class="px-4 py-0">
                <BbDataGrid TData="FileNode" Items="_fileTree"
                            ChildrenSelector="@(f => f.Children)"
                            ItemValueSelector="@(f => f.Id)"
                            DefaultExpandDepth="1"
                            SelectionMode="DataTableSelectionMode.Multiple"
                            HierarchySelectionMode="HierarchySelectionMode.Cascade"
                            ShowExpandAll="true"
                            ShowPagination="false">
                    <Columns>
                        <BbDataGridSelectColumn Pinned="BlazorBlueprint.Primitives.DataGrid.ColumnPinning.Left" />
                        <BbDataGridHierarchyColumn TData="FileNode" TProp="string"
                                                    Property="@(f => f.Name)" Title="Name" Sortable="true" />
                        <BbDataGridTemplateColumn Title="Type" Width="100px">
                            <ChildContent Context="file">
                                <BbBadge Variant="@(file.IsFolder ? BadgeVariant.Secondary : BadgeVariant.Outline)" Class="text-xs">
                                    @(file.IsFolder ? "Folder" : file.Extension)
                                </BbBadge>
                            </ChildContent>
                        </BbDataGridTemplateColumn>
                        <BbDataGridPropertyColumn Property="@(f => f.Size)" Title="Size" Sortable="true"
                                                   CellClass="tabular-nums text-sm text-muted-foreground">
                            <CellTemplate Context="file">
                                <span class="text-sm text-muted-foreground tabular-nums">
                                    @(file.IsFolder ? "--" : FormatSize(file.Size))
                                </span>
                            </CellTemplate>
                        </BbDataGridPropertyColumn>
                        <BbDataGridPropertyColumn Property="@(f => f.Modified)" Format="MMM d, yyyy" Sortable="true"
                                                   CellClass="tabular-nums text-sm text-muted-foreground" />
                    </Columns>
                </BbDataGrid>
            </BbCardContent>
        </BbCard>

        @* ───── 5. Virtualized Large Dataset ───── *@
        <BbCard>
            <BbCardHeader>
                <BbCardTitle>Virtualized Grid (1,000 rows)</BbCardTitle>
                <BbCardDescription>Row virtualization for smooth scrolling over large datasets with sticky header.</BbCardDescription>
            </BbCardHeader>
            <BbCardContent Class="px-4 py-0 pb-4">
                <BbDataGrid TData="LogEntry" ItemsProvider="LoadLogEntries"
                            Virtualize="true"
                            ItemSize="40"
                            VirtualScrollHeight="400px"
                            StickyHeader="true"
                            Striped="true"
                            ShowPagination="false"
                            ShowSearch="true"
                            SearchPlaceholder="Search logs...">
                    <Columns>
                        <BbDataGridPropertyColumn Property="@(l => l.Id)" Title="#" Width="70px"
                                                   Sortable="true" CellClass="tabular-nums font-mono text-xs" />
                        <BbDataGridPropertyColumn Property="@(l => l.Timestamp)" Format="yyyy-MM-dd HH:mm:ss" Width="180px"
                                                   Sortable="true" CellClass="tabular-nums text-sm" />
                        <BbDataGridTemplateColumn Title="Level" Width="110px" Sortable="true">
                            <ChildContent Context="log">
                                <BbBadge Variant="@GetLogLevelVariant(log.Level)" Class="text-xs">@log.Level</BbBadge>
                            </ChildContent>
                        </BbDataGridTemplateColumn>
                        <BbDataGridPropertyColumn Property="@(l => l.Source)" Sortable="true" Filterable="true" Width="160px" />
                        <BbDataGridPropertyColumn Property="@(l => l.Message)" Filterable="true"
                                                   CellClass="text-sm truncate" />
                    </Columns>
                </BbDataGrid>
            </BbCardContent>
        </BbCard>

        @* ───── 6. Single Selection with Row Click ───── *@
        <BbCard>
            <BbCardHeader>
                <div class="flex items-center justify-between">
                    <div>
                        <BbCardTitle>Team Members</BbCardTitle>
                        <BbCardDescription>Single selection mode — click a row to select. Striped rows for readability.</BbCardDescription>
                    </div>
                    @if (_selectedMember != null)
                    {
                        <BbBadge Variant="BadgeVariant.Secondary">
                            Selected: @_selectedMember.Name
                        </BbBadge>
                    }
                </div>
            </BbCardHeader>
            <BbCardContent Class="px-4 py-0">
                <BbDataGrid TData="TeamMember" Items="_teamMembers"
                            SelectionMode="DataTableSelectionMode.Single"
                            SelectedItemsChanged="OnMemberSelected"
                            Striped="true"
                            InitialPageSize="5"
                            ShowPagination="true">
                    <Columns>
                        <BbDataGridTemplateColumn Title="Member" Sortable="true">
                            <ChildContent Context="member">
                                <div class="flex items-center gap-3">
                                    <BbAvatar Class="h-8 w-8">
                                        <BbAvatarFallback Class="text-xs">@member.Initials</BbAvatarFallback>
                                    </BbAvatar>
                                    <div>
                                        <p class="text-sm font-medium">@member.Name</p>
                                        <p class="text-xs text-muted-foreground">@member.Email</p>
                                    </div>
                                </div>
                            </ChildContent>
                        </BbDataGridTemplateColumn>
                        <BbDataGridPropertyColumn Property="@(m => m.Department)" Sortable="true" Filterable="true" />
                        <BbDataGridTemplateColumn Title="Role" Width="140px">
                            <ChildContent Context="member">
                                <BbBadge Variant="@(member.Role == "Lead" ? BadgeVariant.Default : BadgeVariant.Outline)">
                                    @member.Role
                                </BbBadge>
                            </ChildContent>
                        </BbDataGridTemplateColumn>
                        <BbDataGridTemplateColumn Title="Status" Width="120px">
                            <ChildContent Context="member">
                                <div class="flex items-center gap-1.5">
                                    <div class="h-2 w-2 rounded-full @(member.Online ? "bg-green-500" : "bg-muted-foreground/40")"></div>
                                    <span class="text-sm">@(member.Online ? "Online" : "Offline")</span>
                                </div>
                            </ChildContent>
                        </BbDataGridTemplateColumn>
                        <BbDataGridPropertyColumn Property="@(m => m.JoinDate)" Format="MMM yyyy" Sortable="true"
                                                   Title="Joined" CellClass="tabular-nums text-sm text-muted-foreground" />
                    </Columns>
                </BbDataGrid>
            </BbCardContent>
        </BbCard>

        @* ───── 7. Custom Styling Showcase ───── *@
        <BbCard>
            <BbCardHeader>
                <BbCardTitle>Custom Styling</BbCardTitle>
                <BbCardDescription>Showcases every CSS customization parameter: Class, RowClass, CellClass, HeaderClass, StripeClass, TableContainerClass, FilterBarClass, NoWrap, and column pinning.</BbCardDescription>
            </BbCardHeader>
            <BbCardContent Class="px-4 py-0">
                <BbDataGrid TData="ServerMetric" Items="_serverMetrics"
                            Class="rounded-none"
                            TableContainerClass="border border-dashed border-primary/20 rounded-lg"
                            Striped="true"
                            StripeClass="bg-muted/30"
                            RowClass="@(m => m.CpuUsage > 90 ? "!bg-destructive/10 hover:!bg-destructive/15" : m.CpuUsage > 70 ? "!bg-amber-500/10 hover:!bg-amber-500/15" : null)"
                            ShowFilterBar="true"
                            FilterBarClass="bg-muted/50 border-b border-border"
                            ShowPagination="true"
                            InitialPageSize="10"
                            StickyHeader="true">
                    <Columns>
                        <BbDataGridPropertyColumn Property="@(m => m.Name)" Title="Server"
                                                   Sortable="true" Filterable="true"
                                                   HeaderClass="bg-primary/5 font-bold text-primary"
                                                   CellClass="font-semibold"
                                                   Pinned="BlazorBlueprint.Primitives.DataGrid.ColumnPinning.Left"
                                                   NoWrap="true" />
                        <BbDataGridPropertyColumn Property="@(m => m.Region)" Title="Region"
                                                   Sortable="true" Filterable="true"
                                                   HeaderClass="bg-primary/5 font-bold text-primary"
                                                   CellClass="text-muted-foreground text-sm" />
                        <BbDataGridTemplateColumn Title="CPU %" Sortable="true"
                                                   HeaderClass="bg-primary/5 font-bold text-primary text-right"
                                                   CellClass="text-right tabular-nums" Width="120px">
                            <ChildContent Context="metric">
                                <div class="flex items-center justify-end gap-2">
                                    <div class="w-16 h-2 bg-muted rounded-full overflow-hidden">
                                        <div class="h-full rounded-full transition-all @(metric.CpuUsage > 90 ? "bg-destructive" : metric.CpuUsage > 70 ? "bg-amber-500" : "bg-green-500")"
                                             style="width: @(metric.CpuUsage)%"></div>
                                    </div>
                                    <span class="w-10 text-right font-mono text-xs @(metric.CpuUsage > 90 ? "text-destructive font-bold" : metric.CpuUsage > 70 ? "text-amber-500 font-medium" : "text-muted-foreground")">
                                        @metric.CpuUsage%
                                    </span>
                                </div>
                            </ChildContent>
                        </BbDataGridTemplateColumn>
                        <BbDataGridTemplateColumn Title="Memory" Sortable="true"
                                                   HeaderClass="bg-primary/5 font-bold text-primary text-right"
                                                   CellClass="text-right tabular-nums" Width="120px">
                            <ChildContent Context="metric">
                                <div class="flex items-center justify-end gap-2">
                                    <div class="w-16 h-2 bg-muted rounded-full overflow-hidden">
                                        <div class="h-full rounded-full bg-blue-500 transition-all"
                                             style="width: @(metric.MemoryUsage)%"></div>
                                    </div>
                                    <span class="w-10 text-right font-mono text-xs text-muted-foreground">@metric.MemoryUsage%</span>
                                </div>
                            </ChildContent>
                        </BbDataGridTemplateColumn>
                        <BbDataGridPropertyColumn Property="@(m => m.Requests)" Title="Req/s"
                                                   Sortable="true"
                                                   HeaderClass="bg-primary/5 font-bold text-primary"
                                                   CellClass="tabular-nums font-mono text-sm"
                                                   NoWrap="true" Width="100px" />
                        <BbDataGridPropertyColumn Property="@(m => m.Latency)" Title="Latency"
                                                   Sortable="true"
                                                   HeaderClass="bg-primary/5 font-bold text-primary"
                                                   CellClass="tabular-nums font-mono text-sm"
                                                   NoWrap="true" Width="100px">
                            <CellTemplate Context="metric">
                                <span class="font-mono text-xs tabular-nums @(metric.Latency > 200 ? "text-destructive font-bold" : metric.Latency > 100 ? "text-amber-500" : "text-muted-foreground")">
                                    @(metric.Latency)ms
                                </span>
                            </CellTemplate>
                        </BbDataGridPropertyColumn>
                        <BbDataGridTemplateColumn Title="Status" Width="110px"
                                                   HeaderClass="bg-primary/5 font-bold text-primary"
                                                   CellClass="text-center"
                                                   Pinned="BlazorBlueprint.Primitives.DataGrid.ColumnPinning.Right">
                            <ChildContent Context="metric">
                                <BbBadge Variant="@(metric.Status == "Healthy" ? BadgeVariant.Default : metric.Status == "Degraded" ? BadgeVariant.Secondary : BadgeVariant.Destructive)"
                                         Class="text-xs">
                                    @metric.Status
                                </BbBadge>
                            </ChildContent>
                        </BbDataGridTemplateColumn>
                    </Columns>
                </BbDataGrid>
            </BbCardContent>
        </BbCard>

    </ChildContent>
</PageWrapper>

@code {
    // ───── Orders Grid State ─────
    private IReadOnlyCollection<OrderRow> _selectedOrders = Array.Empty<OrderRow>();
    private List<OrderRow> _orders = null!;

    // ───── Team Members State ─────
    private TeamMember? _selectedMember;

    // ───── Virtualized Log State ─────
    private List<LogEntry> _logEntries = null!;

    // ───── File Tree State ─────
    private List<FileNode> _fileTree = null!;

    protected override void OnInitialized()
    {
        _orders = new(_seedOrders);
        _logEntries = GenerateLogEntries(1000);
        _fileTree = GenerateFileTree();
    }

    private void ResetState()
    {
        _selectedOrders = Array.Empty<OrderRow>();
        _selectedMember = null;
        _orders = new(_seedOrders);
    }

    private void AddOrder()
    {
        var id = _orders.Count > 0 ? _orders.Max(o => o.Id) + 1 : 1001;
        var names = new[] { "Emma Wilson", "Liam Johnson", "Sophia Brown", "Noah Davis" };
        var categories = new[] { "Electronics", "Clothing", "Food", "Books", "Home" };
        var statuses = new[] { "Pending", "Processing", "Fulfilled" };
